# ========== MongoDB to ByteHouse 同步配置 ==========

# ========== MongoDB 配置 ==========
MONGO_URI=mongodb://user:password@host:port/?authSource=admin
MONGO_DATABASE=your_database
MONGO_AUTH_SOURCE=admin

# ========== 目标 ByteHouse 配置 ==========
TARGET_BH_HOST=tenant-xxx.bytehouse.volces.com
TARGET_BH_PORT=19000
TARGET_BH_USER=bytehouse
TARGET_BH_PASSWORD=your_password
TARGET_BH_DATABASE=your_database

# ========== 同步配置 ==========
SYNC_BATCH_SIZE=1000
INCREMENTAL_INTERVAL=60
# 要同步的集合，支持逗号分隔多个，支持通配符
# 示例: message_log 或 message_log,user_log 或 *_log
COLLECTION_PATTERN=*

# ========== 日志配置 ==========
LOG_LEVEL=INFO
LOG_FILE=./mongodb_to_bytehouse.log

# ========== 飞书告警配置 ==========
FEISHU_WEBHOOK=
