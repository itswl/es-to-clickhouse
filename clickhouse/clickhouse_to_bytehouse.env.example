# ========== ClickHouse to ByteHouse 同步配置 ==========

# ========== 源 ClickHouse 配置 ==========
SOURCE_CH_HOST=your_clickhouse_host
SOURCE_CH_PORT=9000
SOURCE_CH_USER=default
SOURCE_CH_PASSWORD=your_password
SOURCE_CH_DATABASE=your_database

# ========== 目标 ByteHouse 配置 ==========
TARGET_BH_HOST=tenant-xxx.bytehouse.volces.com
TARGET_BH_PORT=19000
TARGET_BH_USER=bytehouse
TARGET_BH_PASSWORD=your_password
TARGET_BH_DATABASE=your_database

# ========== 同步配置 ==========
SYNC_BATCH_SIZE=10000
INCREMENTAL_INTERVAL=60
# 要同步的表，支持逗号分隔多个，支持通配符
# 示例: spans 或 spans,logs 或 *_log
TABLE_PATTERN=*

# ========== 日志配置 ==========
LOG_LEVEL=INFO
LOG_FILE=./clickhouse_to_bytehouse.log

# ========== 告警通知配置 ==========
FEISHU_WEBHOOK=
